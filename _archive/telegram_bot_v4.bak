@bot.message_handler(func=lambda message: message.text == '🔄 Обработать PDF')
def process_pdfs(message):
    """Обработать PDF файлы"""
    
    if processing_status['is_running']:
        bot.send_message(
            message.chat.id,
            "⚠️ Обработка уже запущена!\nДождитесь завершения."
        )
        return
    
    # Проверить наличие файлов
    try:
        pdf_files = [f for f in os.listdir(PDF_FOLDER) if f.lower().endswith('.pdf')]
        pdf_count = len(pdf_files)
    except Exception as e:
        bot.send_message(
            message.chat.id,
            f"❌ Ошибка доступа к папке:\n{e}"
        )
        return
    
    if pdf_count == 0:
        bot.send_message(
            message.chat.id,
            "📭 <b>Нет файлов для обработки</b>\n\n"
            "Папка EingangsRG пуста",
            parse_mode='HTML'
        )
        return
    
    # Уведомление о начале
    telegram.notify_processing_batch(pdf_count)
    
    processing_status['is_running'] = True
    processing_status['start_time'] = datetime.now()
    
    # Запуск обработки в отдельном потоке
    def run_processing():
        try:
            # Запуск process_pdf_v7_2.py
            result = subprocess.run(
                [sys.executable, SCRIPT_PATH],
                capture_output=True,
                text=True,
                encoding='utf-8',
                timeout=600,
                cwd=os.path.dirname(SCRIPT_PATH)
            )
            
            output = result.stdout
            errors = result.stderr
            
            # Парсинг результатов из вывода
            processed = 0
            duplicates = 0
            manual = 0
            
            for line in output.split('\n'):
                if 'Обработано успешно:' in line or '✓ Обработано успешно:' in line:
                    try:
                        processed = int(line.split(':')[-1].strip())
                    except:
                        pass
                elif 'Дубликатов:' in line or '⚠ Дубликатов:' in line:
                    try:
                        duplicates = int(line.split(':')[-1].strip())
                    except:
                        pass
                elif 'Требуют ручной обработки:' in line or '❌ Требуют ручной обработки:' in line:
                    try:
                        manual = int(line.split(':')[-1].strip())
                    except:
                        pass
            
            # Сохранить результаты
            processing_status['last_results'] = {
                'total': pdf_count,
                'processed': processed,
                'duplicates': duplicates,
                'manual': manual,
                'time': datetime.now()
            }
            
            # Если были ошибки subprocess
            if result.returncode != 0 and errors:
                error_msg = (
                    f"⚠️ <b>Обработка завершена с ошибками</b>\n\n"
                    f"❌ Код возврата: {result.returncode}\n"
                    f"📝 Ошибка: <code>{errors[:200]}</code>\n\n"
                    f"💡 Проверьте логи для деталей"
                )
                bot.send_message(TELEGRAM_CHAT_ID, error_msg, parse_mode='HTML')
            
            # Примечание: Детальные уведомления уже отправлены process_pdf_v7_2.py
            # Здесь только дублирующая финальная сводка для обратной совместимости
            
        except subprocess.TimeoutExpired:
            bot.send_message(
                TELEGRAM_CHAT_ID,
                "⚠️ <b>Таймаут обработки</b>\n\n"
                "Обработка заняла более 10 минут\n"
                "Проверьте состояние системы",
                parse_mode='HTML'
            )
            
        except Exception as e:
            error_msg = (
                f"❌ <b>Критическая ошибка</b>\n\n"
                f"⚠️ {str(e)}\n\n"
                f"💡 Попробуйте запустить process_pdf_v7_2.py вручную"
            )
            bot.send_message(TELEGRAM_CHAT_ID, error_msg, parse_mode='HTML')
            
        finally:
            processing_status['is_running'] = False
            processing_status['last_run'] = datetime.now()
    
    # Запуск в отдельном потоке
    thread = threading.Thread(target=run_processing)
    thread.daemon = True
    thread.start()


@bot.message_handler(func=lambda message: message.text == '📊 Статус')
def show_status(message):
    """Показать статус системы"""
    
    try:
        pdf_count = len([f for f in os.listdir(PDF_FOLDER) if f.lower().endswith('.pdf')])
        manual_count = len([f for f in os.listdir(MANUAL_FOLDER) if f.lower().endswith('.pdf')]) if os.path.exists(MANUAL_FOLDER) else 0
        processed_count = len([f for f in os.listdir(PROCESSED_FOLDER) if f.lower().endswith('.pdf')]) if os.path.exists(PROCESSED_FOLDER) else 0
        
        status_text = "📊 <b>Статус системы</b>\n\n"
        
        if processing_status['is_running']:
            elapsed = datetime.now() - processing_status['start_time']
            minutes = int(elapsed.total_seconds() / 60)
            seconds = int(elapsed.total_seconds() % 60)
            status_text += f"⏳ <b>Обработка запущена</b>\n"
            status_text += f"Прошло: {minutes}:{seconds:02d}\n\n"
        else:
            status_text += "✅ <b>Система готова</b>\n\n"
        
        status_text += "<b>📁 Файлы:</b>\n"
        status_text += f"📥 Входящие: {pdf_count}\n"
        status_text += f"✋ Ручная обработка: {manual_count}\n"
        status_text += f"✅ Обработанные: {processed_count}\n\n"
        
        # Статус мониторинга
        status_text += "<b>🔍 Мониторинг:</b>\n"
        if monitor_settings['enabled'] and file_monitor:
            mon_status = file_monitor.get_status()
            uptime_min = int(mon_status['uptime_seconds'] / 60)
            status_text += f"✅ Включен ({uptime_min} мин)\n"
            status_text += f"📊 Обнаружено: {mon_status['files_detected']}\n"
            auto_status = "✅ Вкл" if monitor_settings['auto_process'] else "⏸️ Выкл"
            status_text += f"🤖 Автообработка: {auto_status}\n"
        else:
            status_text += "⏸️ Выключен\n"
        
        status_text += "\n"
        
        # Последний запуск
        if processing_status['last_run']:
            time_ago = datetime.now() - processing_status['last_run']
            minutes = int(time_ago.total_seconds() / 60)
            hours = int(minutes / 60)
            minutes = minutes % 60
            
            status_text += "<b>🕐 Последний запуск:</b>\n"
            if hours > 0:
                status_text += f"{hours} ч {minutes} мин назад\n"
            else:
                status_text += f"{minutes} мин назад\n"
            
            # Результаты
            if processing_status['last_results']:
                res = processing_status['last_results']
                status_text += f"\n<b>📈 Результаты:</b>\n"
                status_text += f"✅ Успешно: {res['processed']}\n"
                status_text += f"⚠️ Дубликаты: {res['duplicates']}\n"
                status_text += f"❌ Ручные: {res['manual']}\n"
        
        # Статистика Telegram
        tg_stats = telegram.get_stats()
        status_text += f"\n<b>📱 Telegram:</b>\n"
        status_text += f"Отправлено: {tg_stats['sent']}\n"
        status_text += f"Ошибок: {tg_stats['failed']}\n"
        
        bot.send_message(message.chat.id, status_text, parse_mode='HTML')
        
    except Exception as e:
        bot.send_message(
            message.chat.id,
            f"❌ Ошибка получения статуса:\n{e}"
        )


@bot.message_handler(func=lambda message: message.text == '🔍 Мониторинг')
def show_monitoring(message):
    """Показать настройки мониторинга"""
    
    if not MONITOR_AVAILABLE:
        bot.send_message(
            message.chat.id,
            "❌ <b>Мониторинг недоступен</b>\n\n"
            "Модуль file_monitor.py не найден",
            parse_mode='HTML'
        )
        return
    
    monitor_text = "🔍 <b>Автоматический мониторинг файлов</b>\n\n"
    
    if monitor_settings['enabled']:
        monitor_text += "✅ <b>Статус:</b> Включен\n\n"
        
        if file_monitor:
            status = file_monitor.get_status()
            uptime_min = int(status['uptime_seconds'] / 60)
            monitor_text += f"⏱️ Работает: {uptime_min} мин\n"
            monitor_text += f"📊 Обнаружено файлов: {status['files_detected']}\n"
            monitor_text += f"📁 Папка: EingangsRG\n\n"
        
        auto_status = "✅ Включена" if monitor_settings['auto_process'] else "⏸️ Выключена"
        monitor_text += f"🤖 <b>Автообработка:</b> {auto_status}\n"
        monitor_text += "При обнаружении нового файла:\n"
        if monitor_settings['auto_process']:
            monitor_text += "• Автоматически запускается обработка\n"
        else:
            monitor_text += "• Присылается уведомление\n"
    else:
        monitor_text += "⏸️ <b>Статус:</b> Выключен\n\n"
        monitor_text += "Нажмите ▶️ Запустить для активации"
    
    bot.send_message(
        message.chat.id,
        monitor_text,
        reply_markup=get_monitor_keyboard(),
        parse_mode='HTML'
    )


# ===== ОБРАБОТЧИКИ CALLBACK =====

@bot.callback_query_handler(func=lambda call: call.data.startswith('monitor_'))
def handle_monitor_callback(call):
    """Обработка кнопок мониторинга"""
    
    if call.data == 'monitor_start':
        success, msg = start_monitor()
        if success:
            bot.answer_callback_query(call.id, "✅ Мониторинг запущен")
        else:
            bot.answer_callback_query(call.id, f"❌ Ошибка: {msg}")
        show_monitoring(call.message)
        
    elif call.data == 'monitor_stop':
        success, msg = stop_monitor()
        if success:
            bot.answer_callback_query(call.id, "⏸️ Мониторинг остановлен")
        else:
            bot.answer_callback_query(call.id, f"❌ Ошибка: {msg}")
        show_monitoring(call.message)
        
    elif call.data == 'monitor_status':
        bot.answer_callback_query(call.id, "📊 Обновление статуса")
        show_monitoring(call.message)
        
    elif call.data == 'monitor_toggle_auto':
        monitor_settings['auto_process'] = not monitor_settings['auto_process']
        status = "включена" if monitor_settings['auto_process'] else "выключена"
        bot.answer_callback_query(call.id, f"🤖 Автообработка {status}")
        show_monitoring(call.message)


@bot.callback_query_handler(func=lambda call: call.data == 'back_to_main')
def back_to_main(call):
    """Вернуться к главному меню"""
    bot.answer_callback_query(call.id)
    bot.delete_message(call.message.chat.id, call.message.message_id)


