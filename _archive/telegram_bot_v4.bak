# ===== ФУНКЦИИ МОНИТОРИНГА =====

def init_file_monitor():
    """Инициализировать мониторинг файлов"""
    global file_monitor
    
    if not MONITOR_AVAILABLE:
        return False
    
    try:
        if file_monitor is None:
            file_monitor = FileMonitor(PDF_FOLDER, on_new_file_detected)
        return True
    except Exception as e:
        print(f"Ошибка инициализации мониторинга: {e}")
        return False


def on_new_file_detected(file_path, filename, file_size):
    """Callback при обнаружении нового файла"""
    try:
        # Отправить уведомление через unified_telegram
        timestamp = datetime.now().strftime('%H:%M:%S')
        telegram.notify_new_file(filename, file_size, timestamp)
        
        # Если включена автообработка
        if monitor_settings.get('auto_process', False):
            import time
            time.sleep(2)
            
            # Создать фейковое сообщение для запуска обработки
            class FakeMessage:
                chat = type('obj', (object,), {'id': TELEGRAM_CHAT_ID})
            
            process_pdfs(FakeMessage())
            
    except Exception as e:
        print(f"Ошибка обработки нового файла: {e}")


def start_monitor():
    """Запустить мониторинг"""
    global file_monitor, monitor_settings
    
    if not MONITOR_AVAILABLE:
        return False, "Модуль file_monitor не найден"
    
    try:
        if file_monitor is None:
            if not init_file_monitor():
                return False, "Ошибка инициализации"
        
        file_monitor.start()
        monitor_settings['enabled'] = True
        return True, "Мониторинг запущен"
        
    except Exception as e:
        return False, str(e)


def stop_monitor():
    """Остановить мониторинг"""
    global file_monitor, monitor_settings
    
    try:
        if file_monitor:
            file_monitor.stop()
            monitor_settings['enabled'] = False
            return True, "Мониторинг остановлен"
        return False, "Мониторинг не запущен"
    except Exception as e:
        return False, str(e)


