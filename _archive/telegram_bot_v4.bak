def get_main_keyboard():
    """Главная клавиатура"""
    keyboard = types.ReplyKeyboardMarkup(resize_keyboard=True, row_width=2)
    
    btn1 = types.KeyboardButton('🔄 Обработать PDF')
    btn2 = types.KeyboardButton('📊 Статус')
    btn3 = types.KeyboardButton('🔍 Мониторинг')
    btn4 = types.KeyboardButton('ℹ️ Помощь')
    
    keyboard.add(btn1, btn2)
    keyboard.add(btn3, btn4)
    
    return keyboard


def get_monitor_keyboard():
    """Клавиатура мониторинга"""
    markup = types.InlineKeyboardMarkup(row_width=2)
    
    if monitor_settings['enabled']:
        markup.add(
            types.InlineKeyboardButton("⏸️ Остановить", callback_data="monitor_stop"),
            types.InlineKeyboardButton("📊 Статус", callback_data="monitor_status")
        )
        
        auto_text = "🤖 Выкл автообработку" if monitor_settings['auto_process'] else "🤖 Вкл автообработку"
        markup.add(types.InlineKeyboardButton(auto_text, callback_data="monitor_toggle_auto"))
    else:
        markup.add(types.InlineKeyboardButton("▶️ Запустить", callback_data="monitor_start"))
    
    markup.add(types.InlineKeyboardButton("🔙 Назад", callback_data="back_to_main"))
    
    return markup


